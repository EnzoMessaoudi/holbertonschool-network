#!/usr/bin/env bash
# Configures /etc/hosts so that:
#   localhost   -> 127.0.0.2
#   facebook.com -> 8.8.8.8

HOSTS_FILE="/etc/hosts"

# Update or insert the localhost entry (127.0.0.2)
if grep -qP "^\s*127\.[0-9]+\.[0-9]+\.[0-9]+\s+localhost" "$HOSTS_FILE"; then
    # Replace any existing localhost line with the new IP
    sed -i 's/^\s*127\.[0-9]\+\.[0-9]\+\.[0-9]\+\s\+localhost.*/127.0.0.2\tlocalhost/' "$HOSTS_FILE"
else
    echo -e "127.0.0.2\tlocalhost" >> "$HOSTS_FILE"
fi

# Update or insert the facebook.com entry (8.8.8.8)
if grep -qP "^\s*[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\s+facebook\.com" "$HOSTS_FILE"; then
    # Replace any existing facebook.com line with the new IP
    sed -i 's/^\s*[0-9]\+\.[0-9]\+\.[0-9]\+\.[0-9]\+\s\+facebook\.com.*/8.8.8.8\tfacebook.com/' "$HOSTS_FILE"
else
    echo -e "8.8.8.8\tfacebook.com" >> "$HOSTS_FILE"
fi
