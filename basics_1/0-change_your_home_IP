#!/usr/bin/env bash
# Configures /etc/hosts so that:
#   localhost    -> 127.0.0.2
#   facebook.com -> 8.8.8.8

HOSTS_FILE="/etc/hosts"

# Use awk to rewrite the file in memory, then write back with tee
# This avoids sed -i renaming issues on busy/bind-mounted files

awk '
{
    # Replace localhost entry
    if ($0 ~ /^[[:space:]]*[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+[[:space:]]+localhost/) {
        print "127.0.0.2\tlocalhost"
        next
    }
    # Replace facebook.com entry
    if ($0 ~ /^[[:space:]]*[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+[[:space:]]+facebook\.com/) {
        print "8.8.8.8\tfacebook.com"
        next
    }
    print
}
' "$HOSTS_FILE" > /tmp/hosts.tmp

# Check if entries exist; if not, append them
grep -qE "^[0-9.]+[[:space:]]+localhost" /tmp/hosts.tmp      || echo -e "127.0.0.2\tlocalhost"    >> /tmp/hosts.tmp
grep -qE "^[0-9.]+[[:space:]]+facebook\.com" /tmp/hosts.tmp  || echo -e "8.8.8.8\tfacebook.com"   >> /tmp/hosts.tmp

# Write back to /etc/hosts without renaming (cat avoids the inode swap)
cat /tmp/hosts.tmp > "$HOSTS_FILE"
rm -f /tmp/hosts.tmp
